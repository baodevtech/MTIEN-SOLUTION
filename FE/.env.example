# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL=https://minhtiensolutions.com

# ========================================
# Admin API Connection
# ========================================

# Admin API URL (server-side, for theme fetching)
ADMIN_API_URL=https://portal.minhtiensolutions.cloud

# Admin API URL (client-side, for contact form)
NEXT_PUBLIC_ADMIN_API_URL=https://portal.minhtiensolutions.cloud

# Shared secret key — must match the key in Admin > Settings > Kết nối Frontend
REVALIDATION_SECRET=your-secret-key-here

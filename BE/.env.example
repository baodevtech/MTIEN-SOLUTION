# ========================================
# Admin CMS Environment Variables
# ========================================
# Copy this file to `.env.local` (for Next.js) or `.env` (for Docker Compose)
# and fill in real values. Never commit secrets.

NODE_ENV=development

# Database — REQUIRED
DATABASE_URL=postgresql://mtien:CHANGE_ME@localhost:5432/mtien_solution?schema=public

# PostgreSQL (only used by docker-compose.yml) — REQUIRED when using Docker
POSTGRES_USER=mtien
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=mtien_solution

# Auth — REQUIRED (min 32 chars). Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_A_RANDOM_STRING_AT_LEAST_32_CHARS_LONG
# Token lifetime in seconds (default 7 days)
JWT_EXPIRES_IN_SECONDS=604800

# Data directory path for theme files
DATA_DIR=./data

# Frontend origin(s) for CORS — REQUIRED.
# Comma-separated list of exact origins. Wildcard (*) is rejected in production.
FRONTEND_ORIGIN=http://localhost:3000,https://minhtiensolutions.com

# Optional API key for public/internal integrations (min 16 chars)
# PUBLIC_API_KEY=

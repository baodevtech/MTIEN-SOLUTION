generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────
// ─── Category & Tag ───────────────────────────────
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  type      String   // 'post' | 'product' | 'project' | ...
  icon      String?
  desc      String?
  status    String   @default("active")
  posts     Post[]
  products  Product[]
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  type      String   // 'post' | 'product' | 'project' | ...
  desc      String?
  status    String   @default("active")
  posts     Post[]   @relation("PostTags", references: [id])
  products  Product[] @relation("ProductTags", references: [id])
  projects  Project[] @relation("ProjectTags", references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([createdAt])
}

// ─── Products ────────────────────────────────────────
model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  price       Float
  comparePrice Float?
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  status      String      @default("active")
  stock       Int         @default(0)
  sku         String?
  image       String?
  images      String[]    @default([])
  tags        Tag[]       @relation("ProductTags")
  featured    Boolean     @default(false)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([status, categoryId])
  @@index([createdAt])
}

// ─── Posts / Blog ────────────────────────────────────
model Post {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String?
  content         String?
  coverImage      String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]    @relation("PostTags")
  author          String?
  status          String   @default("draft")
  views           Int      @default(0)
  // SEO fields
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String[] @default([])
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  noIndex         Boolean  @default(false)
  seoScore        Int      @default(0)
  seoIssues       Json?    // Store last analysis result

  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([createdAt])
}

// ─── Contacts ────────────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

// ─── Orders ──────────────────────────────────────────
model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerName  String
  customerEmail String
  customerPhone String?
  customerAddress String?
  items         OrderItem[]
  total         Float
  status        String      @default("pending")
  paymentMethod String?
  paymentStatus String      @default("pending")
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  price     Float
  quantity  Int
  image     String?

  @@index([orderId])
  @@index([productId])
}

// ─── Media ───────────────────────────────────────────
model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  url          String
  type         String   @default("image")
  size         Int      @default(0)
  width        Int?
  height       Int?
  alt          String?
  folder       String?
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([folder])
  @@index([type])
  @@index([createdAt])
}

// ─── Settings (key-value store) ──────────────────────
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

// ─── Services ────────────────────────────────────────
model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  shortDesc   String?
  icon        String?
  features    Json     @default("[]")
  pricing     Json     @default("[]")
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([order])
}

// ─── Projects ────────────────────────────────────────
model Project {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  client       String
  description  String?
  images       String[]  @default([])
  technologies String[]  @default([])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  tags         Tag[]     @relation("ProjectTags")
  status       String    @default("planned")
  featured     Boolean   @default(false)
  url          String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([completedAt])
  @@index([createdAt])
}

// ─── Site Pages ──────────────────────────────────────
model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @default("")
  template  String   @default("default")
  status    String   @default("published")
  seo       Json     @default("{}")
  order     Int      @default(0)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([parentId])
  @@index([order])
}

// ─── Analytics ───────────────────────────────────────
model Analytics {
  id        String   @id @default(cuid())
  date      DateTime
  metric    String
  value     Int
  path      String?
  source    String?
  createdAt DateTime @default(now())

  @@index([date, metric])
  @@index([metric, source])
}

// ─── Theme Config (replaces file-based JSON) ─────────
model ThemeConfig {
  id          String   @id @default(cuid())
  type        String   @unique // 'draft' | 'published'
  config      Json
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ThemeVersion {
  id        String   @id @default(cuid())
  name      String   @unique
  config    Json
  createdAt DateTime @default(now())
}

// ─── Connection Settings (replaces connection.json) ──
model ConnectionSetting {
  id            String   @id @default(cuid())
  frontendUrl   String   @default("")
  secretKey     String   @default("")
  lastConnected DateTime?
  updatedAt     DateTime @updatedAt
}

// ─── Activity Logs ───────────────────────────────────
model ActivityLog {
  id         String   @id @default(cuid())
  action     String   // 'theme.save-draft' | 'theme.publish' | 'post.create' | etc.
  module     String   // 'theme' | 'post' | 'product' | 'order' | 'contact' | 'settings' | etc.
  status     String   // 'success' | 'failed' | 'warning'
  message    String   // Human-readable description
  detail     Json?    // Extra structured data (error codes, HTTP status, payloads, etc.)
  userId     String?  // Who performed the action
  userName   String?  // Denormalised for quick display
  ip         String?
  duration   Int?     // milliseconds
  createdAt  DateTime @default(now())

  @@index([module])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@index([module, createdAt])
}
